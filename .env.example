DATABASE_URL=postgresql+asyncpg://user:password@host/dbname
SESSION_SECRET=replace-with-a-long-random-string-32-chars-min
FOOTBALL_API_KEY=your-key-from-sports.bzzoiro.com
FOOTBALL_API_BASE_URL=https://sports.bzzoiro.com/api/v2
FOOTBALL_LEAGUE_ID=27
TASK_SECRET=replace-with-another-long-random-string
DEBUG=false

# Staging only — map date ranges to round names for leagues that return empty round_name.
# Lets you test the full round-wager flow with a live active league that has no round structure.
# Dates are compared against kickoff_time in UTC — use UTC dates in the ranges.
# Leave unset in production (World Cup provides its own round names via the API).
# Note: wrap in single quotes so the shell doesn't strip the inner double quotes.
# ROUND_DATE_RULES='[{"from":"2026-06-01","to":"2026-06-07","name":"Group Stage"},{"from":"2026-06-08","to":"2026-06-09","name":"Round of 16"},{"from":"2026-06-10","to":"2026-06-10","name":"Quarterfinals"},{"from":"2026-06-11","to":"2026-06-11","name":"Semifinals"},{"from":"2026-06-12","to":"2026-06-12","name":"Final"}]'
